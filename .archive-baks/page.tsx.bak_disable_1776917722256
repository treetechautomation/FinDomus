import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import { cards, transactions } from "@/lib/data";
import { PlusCircle } from "lucide-react";

export default function CartoesPage() {
  const getCardSpendingPercentage = (spent: number, limit: number) => {
    return (spent / limit) * 100;
  };

  return (
    <div className="space-y-6">
      <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <h1 className="text-2xl md:text-3xl font-bold tracking-tight">Meus Cartões</h1>
        <Button>
          <PlusCircle className="mr-2 h-4 w-4" />
          Adicionar Cartão
        </Button>
      </div>

      <div className="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {cards.map((card) => (
          <Card key={card.id}>
            <CardHeader>
              <CardTitle className="flex items-center justify-between">
                <span>{card.name}</span>
                <span className="text-sm font-normal text-muted-foreground">Final {card.last4}</span>
              </CardTitle>
              <CardDescription>
                Fecha em: {card.closingDate} - Vence em: {card.dueDate}
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <div className="flex justify-between mb-1">
                  <span className="text-sm font-medium">
                    {card.spent.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  </span>
                  <span className="text-sm text-muted-foreground">
                    / {card.limit.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  </span>
                </div>
                <Progress value={getCardSpendingPercentage(card.spent, card.limit)} />
                <p className="text-xs text-muted-foreground mt-1">
                  {getCardSpendingPercentage(card.spent, card.limit).toFixed(0)}% do limite utilizado
                </p>
              </div>
              <div>
                <h4 className="font-medium text-sm mb-2">Despesas Recentes</h4>
                <Table>
                  <TableBody>
                    {transactions.filter(t => t.account === 'Cartão de Crédito').slice(0, 3).map(t => (
                      <TableRow key={t.id}>
                        <TableCell className="p-2">{t.description}</TableCell>
                        <TableCell className="p-2 text-right font-mono text-sm">
                          {t.amount.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  );
}
