'use client';

import { useState } from 'react';
import { useDropzone } from 'react-dropzone';
import { UploadCloud, File as FileIcon, X, Loader, Wand2, CheckCircle, ArrowRight } from 'lucide-react';
import { Button } from '../ui/button';
import { Card, CardContent } from '../ui/card';
import { cn } from '@/lib/utils';
import { parseBankStatementText, parseNubankCSV } from '@/core/finance/invoice-parser';
import { parseOFX } from '@/core/finance/ofx-parser';
import { parseExcelFile } from '@/core/finance/excel-parser';
import { handleFileExtract } from '@/lib/actions';
import type { ExtractTransactionsFromDocumentOutput } from '@/ai/flows/extract-transactions-from-document';
import { useToast } from '@/hooks/use-toast';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '../ui/table';
import { Input } from '../ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../ui/select';

type ExtractedTransaction = ExtractTransactionsFromDocumentOutput[0];

const fileToBase64 = (file: File): Promise<string> => {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.readAsDataURL(file);
    reader.onload = () => resolve(reader.result as string);
    reader.onerror = (error) => reject(error);
  });
};

export function Importer() {
  const [step, setStep] = useState(1);
  const [file, setFile] = useState<File | null>(null);
  const [transactions, setTransactions] = useState<ExtractedTransaction[]>([]);
  const [isLoading, setIsLoading] = useState(false);
  const { toast } = useToast();

  const onDrop = (acceptedFiles: File[]) => {
    if (acceptedFiles.length > 0) {
      setFile(acceptedFiles[0]);
    }
  };

  const { getRootProps, getInputProps, isDragActive } = useDropzone({
    onDrop,
    accept: {
      'application/pdf': ['.pdf'],
      'text/csv': ['.csv'],
      'application/vnd.ms-excel': ['.xls'],
      'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': ['.xlsx'],
      'application/x-ofx': ['.ofx'],
      'text/plain': ['.ofx', '.txt'],
      'image/png': ['.png'],
      'image/jpeg': ['.jpg', '.jpeg'],
    },
    multiple: false,
  });

  const processFile = async () => {
    if (!file) return;
    setIsLoading(true);

    try {
      const fileName = file.name.toLowerCase();
      let text = '';
      let parsed: any[] = [];

      if (fileName.endsWith('.pdf')) {
        const formData = new FormData();
        formData.append('file', file);

        const res = await fetch('/api/import/pdf', {
          method: 'POST',
          body: formData,
        });

        const rawResponse = await res.text();

        let data: any = {};
        try {
          data = JSON.parse(rawResponse);
        } catch {
          throw new Error(rawResponse || 'Resposta inválida da API PDF');
        }

        if (!res.ok || !data.text) {
          throw new Error(data.error || 'Falha ao extrair texto do PDF');
        }

        parsed = parseBankStatementText(data.text);

        if (!parsed.length) {
          const dataUri = await fileToBase64(file);
          const aiResult = await handleFileExtract(dataUri);

          if (!aiResult.success || !aiResult.data?.length) {
            throw new Error(aiResult.error || 'PDF lido, mas nenhum lançamento foi identificado.');
          }

          parsed = aiResult.data.map((item: any) => {
            const rawAmount = Number(item.value || 0);
            const type = item.transactionType === 'income' ? 'income' : 'expense';

            return {
              date: item.date || '',
              description: item.description || 'Lançamento importado',
              amount: Math.abs(rawAmount),
              category: item.suggestedCategory || 'Outros',
              merchant: item.merchant || '',
              type,
            };
          });
        }
      } else if (fileName.endsWith('.ofx')) {
        text = await file.text();
        parsed = parseOFX(text);
      } else if (fileName.endsWith('.xlsx') || fileName.endsWith('.xls')) {
        parsed = parseExcelFile(await file.arrayBuffer());
      } else {
        text = await file.text();
        parsed = parseNubankCSV(text);
      }

      if (!parsed.length) {
        throw new Error('Nenhum lançamento encontrado no arquivo. Verifique se o arquivo está em CSV, OFX ou Excel com colunas de Data, Descrição e Valor.');
      }

      setTransactions(parsed.map((t) => ({
        date: t.date,
        description: t.description,
        amount: t.amount,
        category: t.category,
        merchant: t.merchant,
        type: t.type,
      })));

      setStep(2);
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Erro inesperado',
        description: error instanceof Error ? error.message : 'Falha ao processar arquivo com parser.',
      });
    } finally {
      setIsLoading(false);
    }
  };

  const cancelImport = () => {
    setFile(null);
    setTransactions([]);
    setStep(1);
  };

  const confirmImport = () => {
    // In a real app, this would save the transactions to the database
    setStep(3);
    setTimeout(() => {
        setFile(null);
        setTransactions([]);
        setStep(1);
        toast({
            title: 'Importação Concluída!',
            description: `${transactions.length} transações foram importadas com sucesso.`,
          });
    }, 2000);
  };
  
  const handleFieldChange = (index: number, field: keyof ExtractedTransaction, value: string | number) => {
    const updatedTransactions = [...transactions];
    (updatedTransactions[index] as any)[field] = value;
    setTransactions(updatedTransactions);
  };

  return (
    <div className="space-y-6">
      <Card>
        <CardContent className="p-6">
          <div className="flex justify-around items-start text-center">
            <div className="flex flex-col items-center gap-2">
              <div className={cn("w-10 h-10 rounded-full flex items-center justify-center", step >= 1 ? "bg-primary text-primary-foreground" : "bg-muted")}>
                {step > 1 ? <CheckCircle size={20} /> : '1'}
              </div>
              <p className={cn("font-medium", step >= 1 && "text-primary")}>Enviar Arquivo</p>
            </div>
            <div className="flex-1 self-center pb-6">
                <hr className={cn("border-dashed", step >= 2 && "border-primary")}/>
            </div>
            <div className="flex flex-col items-center gap-2">
              <div className={cn("w-10 h-10 rounded-full flex items-center justify-center", step >= 2 ? "bg-primary text-primary-foreground" : "bg-muted")}>
                 {step > 2 ? <CheckCircle size={20} /> : '2'}
              </div>
              <p className={cn("font-medium", step >= 2 && "text-primary")}>Revisar Lançamentos</p>
            </div>
            <div className="flex-1 self-center pb-6">
                <hr className={cn("border-dashed", step >= 3 && "border-primary")}/>
            </div>
            <div className="flex flex-col items-center gap-2">
              <div className={cn("w-10 h-10 rounded-full flex items-center justify-center", step >= 3 ? "bg-primary text-primary-foreground" : "bg-muted")}>
                3
              </div>
              <p className={cn("font-medium", step >= 3 && "text-primary")}>Confirmar</p>
            </div>
          </div>
        </CardContent>
      </Card>

      {step === 1 && (
        <Card>
          <CardContent className="p-6 text-center">
            {!file ? (
              <div {...getRootProps()} className={cn("border-2 border-dashed rounded-lg p-12 cursor-pointer", isDragActive ? "border-primary bg-secondary" : "border-border")}>
                <input {...getInputProps()} />
                <UploadCloud className="mx-auto h-12 w-12 text-muted-foreground" />
                <p className="mt-4">Arraste e solte o arquivo aqui, ou clique para selecionar.</p>
                <p className="text-sm text-muted-foreground">Suporta PDF, CSV, OFX, XLS, XLSX, PNG e JPG</p>
              </div>
            ) : (
              <div className="flex items-center justify-between p-4 border rounded-lg">
                <div className="flex items-center gap-4">
                  <FileIcon className="h-8 w-8 text-primary" />
                  <div>
                    <p className="font-medium">{file.name}</p>
                    <p className="text-sm text-muted-foreground">{(file.size / 1024).toFixed(2)} KB</p>
                  </div>
                </div>
                <Button variant="ghost" size="icon" onClick={() => setFile(null)}>
                  <X className="h-4 w-4" />
                </Button>
              </div>
            )}
            <Button onClick={processFile} disabled={!file || isLoading} className="mt-6 w-full max-w-sm mx-auto">
              {isLoading ? <Loader className="mr-2 h-4 w-4 animate-spin" /> : <Wand2 className="mr-2 h-4 w-4" />}
              {isLoading ? 'Processando...' : 'Processar Leitura'}
            </Button>
          </CardContent>
        </Card>
      )}
      
      {step === 2 && (
        <Card>
            <CardContent className="p-6">
                <h2 className="text-xl font-semibold mb-4">Revise os lançamentos encontrados</h2>
                <div className="overflow-x-auto">
                    <Table>
                        <TableHeader>
                            <TableRow>
                                <TableHead>Data</TableHead>
                                <TableHead>Descrição</TableHead>
                                <TableHead>Valor</TableHead>
                                <TableHead>Categoria</TableHead>
                                  <TableHead>Loja</TableHead>
                                <TableHead>Tipo</TableHead>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            {transactions.map((t, index) => (
                                <TableRow key={index}>
                                    <TableCell><Input value={t.date} onChange={(e) => handleFieldChange(index, 'date', e.target.value)} /></TableCell>
                                    <TableCell><Input value={t.description} onChange={(e) => handleFieldChange(index, 'description', e.target.value)}/></TableCell>
                                    <TableCell><Input type="number" value={t.amount} onChange={(e) => handleFieldChange(index, 'value', parseFloat(e.target.value))} /></TableCell>
                                    <TableCell><Input value={t.category} onChange={(e) => handleFieldChange(index, 'category', e.target.value)} /></TableCell>
                                      <TableCell><Input value={t.merchant} onChange={(e) => handleFieldChange(index, 'merchant', e.target.value)} /></TableCell>
                                      <TableCell><Input value={t.category} onChange={(e) => handleFieldChange(index, 'category', e.target.value)} /></TableCell>
                                    <TableCell>
                                        <Select value={t.type} onValueChange={(val) => handleFieldChange(index, 'type', val)}>
                                            <SelectTrigger><SelectValue/></SelectTrigger>
                                            <SelectContent>
                                                <SelectItem value="income">Receita</SelectItem>
                                                <SelectItem value="expense">Despesa</SelectItem>
                                            </SelectContent>
                                        </Select>
                                    </TableCell>
                                </TableRow>
                            ))}
                        </TableBody>
                    </Table>
                </div>
                <div className="flex justify-end mt-6">
                    <Button onClick={confirmImport}>
                        Confirmar Importação <ArrowRight className="ml-2 h-4 w-4" />
                    </Button>
                </div>
            </CardContent>
        </Card>
      )}

      {step === 3 && (
        <Card>
            <CardContent className="p-12 text-center">
                <CheckCircle className="mx-auto h-16 w-16 text-green-500" />
                <h2 className="mt-4 text-2xl font-semibold">Importação em andamento!</h2>
                <p className="text-muted-foreground mt-2">Suas transações estão sendo salvas. Você será notificado em breve.</p>
            </CardContent>
        </Card>
      )}
    </div>
  );
}
