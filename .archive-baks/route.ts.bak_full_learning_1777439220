import { NextResponse } from 'next/server';
import { classifyPixFlow } from '@/ai/flows/classify-pix';
import { canUseAI, registerAIUsage } from '@/core/ai/usage';
import { getCategories } from '@/services/firestore';

export async function POST(req: Request) {
  try {
    
const { text, amount, userId } = await req.json();

if (!userId) {
  return NextResponse.json({ error: 'userId obrigatório' }, { status: 400 });
}

const allowed = await canUseAI(userId);

if (!allowed) {
  return NextResponse.json({
    error: 'Limite de IA atingido',
    type: 'limit'
  }, { status: 403 });
}


    const result = await classifyPixFlow({
      text,
      amount,
    });

    
await registerAIUsage(userId);
return NextResponse.json({
  ...result,
  category: result.type === 'income' ? 'Recebimentos' : 'Transferência',
  source: 'ai',
});

  } catch (error) {
    console.error(error);
    return NextResponse.json({ error: 'Erro IA PIX' }, { status: 500 });
  }
}
