export async function updateAccount(
  accountId: string,
  data: {
    name?: string;
    type?: string;
    owner?: "PF" | "PJ";
    companyId?: string | null;
    balance?: number;
  }
) {
  const ref = doc(db, "accounts", accountId);
  await updateDoc(ref, data);
}
