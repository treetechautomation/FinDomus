              </CardHeader>
            </Card>

            <Card className="border-orange-500/40 bg-card/70">
              <CardHeader>
                <CardDescription>Parcelas</CardDescription>
                <CardTitle className="text-2xl text-orange-400">{brl(monthlyLiabilities)}</CardTitle>
              </CardHeader>
