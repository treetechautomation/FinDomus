            <Card className="border-emerald-500/40 bg-card/70">
              <CardHeader>
                <CardDescription>Saldo planejado</CardDescription>
                <CardTitle className={monthlyIncome - totalOutflow >= 0 ? "text-2xl text-emerald-500" : "text-2xl text-red-500"}>
