import * as XLSX from 'xlsx';

import { classifyTransaction, type ParsedTransaction } from './transaction-classifier';

function findValue(row: any, keys: string[]) {
  const normalizedKeys = Object.keys(row);
  const found = normalizedKeys.find((key) =>
    keys.some((target) => key.toLowerCase().includes(target.toLowerCase()))
  );
  return found ? row[found] : '';
}

export function parseExcelFile(buffer: ArrayBuffer): ParsedTransaction[] {
  const workbook = XLSX.read(buffer, { type: 'array' });
  const sheet = workbook.Sheets[workbook.SheetNames[0]];
  const rows = XLSX.utils.sheet_to_json(sheet);

  return rows
    .map((row: any) => {
      const date = String(findValue(row, ['data', 'date']) || '');
      const description = String(findValue(row, ['descrição', 'descricao', 'histórico', 'historico', 'title', 'memo']) || '');
      const amount = Number(String(findValue(row, ['valor', 'amount'])).replace(/\./g, '').replace(',', '.'));

      if (!description || Number.isNaN(amount)) return null;

      return {
        ...classifyTransaction(description, amount),
        date,
      };
    })
    .filter(Boolean) as ParsedTransaction[];
}
