import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";
import { budgetPlanning } from "@/lib/data";
import { cn } from "@/lib/utils";
import { FileEdit } from "lucide-react";

export default function PlanejamentoPage() {
  const getSpendingProgress = (spent: number, planned: number) => {
    if (planned === 0) return 0;
    const progress = (spent / planned) * 100;
    return Math.min(progress, 100);
  };

  const getStatusColor = (spent: number, planned: number) => {
    const progress = (spent / planned) * 100;
    if (progress > 100) return 'bg-red-500';
    if (progress > 80) return 'bg-yellow-500';
    return 'bg-primary';
  };

  const totalPlanned = budgetPlanning.reduce((sum, item) => sum + item.planned, 0);
  const totalSpent = budgetPlanning.reduce((sum, item) => sum + item.spent, 0);

  return (
    <div className="space-y-6">
      <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <h1 className="text-2xl md:text-3xl font-bold tracking-tight">Planejamento Mensal</h1>
        <Button variant="outline">
          <FileEdit className="mr-2 h-4 w-4" />
          Editar Orçamento
        </Button>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Resumo do Orçamento</CardTitle>
          <CardDescription>Acompanhe seus gastos em relação ao que foi planejado.</CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
            <div className="space-y-2">
                <div className="flex justify-between text-lg font-medium">
                    <span>Total Gasto</span>
                    <span>{totalSpent.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</span>
                </div>
                <div className="flex justify-between text-muted-foreground">
                    <span>Total Planejado</span>
                    <span>{totalPlanned.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</span>
                </div>
            </div>
            <Progress value={(totalSpent / totalPlanned) * 100} />
        </CardContent>
      </Card>
      
      <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {budgetPlanning.map((budget) => (
          <Card key={budget.category}>
            <CardHeader className="pb-2">
              <CardTitle className="text-base font-medium">{budget.category}</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-2">
                <Progress value={getSpendingProgress(budget.spent, budget.planned)} indicatorClassName={getStatusColor(budget.spent, budget.planned)} />
                <div className="flex justify-between text-sm">
                  <span className="text-muted-foreground">Gasto</span>
                  <span>{budget.spent.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</span>
                </div>
                <div className="flex justify-between text-sm">
                  <span className="text-muted-foreground">Planejado</span>
                  <span>{budget.planned.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</span>
                </div>
                {budget.spent > budget.planned && (
                    <Badge variant="destructive">Orçamento excedido</Badge>
                )}
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  );
}
