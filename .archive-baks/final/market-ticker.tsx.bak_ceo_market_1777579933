'use client';

import { useEffect, useMemo, useState } from 'react';

type MarketTickerItem = {
  symbol: string;
  name?: string;
  price: number;
  change: number;
};

function money(value: number) {
  return Number(value || 0).toLocaleString('pt-BR', {
    style: 'currency',
    currency: 'BRL',
  });
}

function formatChange(value: number) {
  const n = Number(value || 0);
  return `${n >= 0 ? '+' : '-'}${Math.abs(n).toFixed(2)}%`;
}

export function MarketTicker() {
  const [items, setItems] = useState<MarketTickerItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [updatedAt, setUpdatedAt] = useState('');

  async function loadMarket() {
    try {
      const res = await fetch('/api/market/tickers', { cache: 'no-store' });
      const json = await res.json();

      if (json?.ok && Array.isArray(json.data)) {
        setItems(json.data);
        setUpdatedAt(new Date().toLocaleTimeString('pt-BR', {
          hour: '2-digit',
          minute: '2-digit',
        }));
      }
    } catch {
      setItems([]);
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadMarket();

    const timer = window.setInterval(() => {
      loadMarket();
    }, 60000);

    return () => window.clearInterval(timer);
  }, []);

  const insights = useMemo(() => {
    const valid = items.filter((item) => typeof item.change === 'number' && !isNaN(item.change));

    const best = [...valid].sort((a, b) => b.change - a.change)[0];
    const worst = [...valid].sort((a, b) => a.change - b.change)[0];

    return { best, worst };
  }, [items]);

  const marqueeItems = useMemo(() => {
    const fallback = [
      { symbol: 'IBOV', price: 0, change: 0 },
      { symbol: 'PETR4', price: 0, change: 0 },
      { symbol: 'VALE3', price: 0, change: 0 },
      { symbol: 'ITUB4', price: 0, change: 0 },
      { symbol: 'BTC', price: 0, change: 0 },
    ];

    const base = items.length ? items : fallback;
    return [...base, ...base];
  }, [items]);

  return (
    <div className="border-y border-border/70 bg-background/85 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div className="flex h-12 items-center overflow-hidden">
        <div className="flex h-full shrink-0 items-center gap-3 border-r border-border/70 px-4">
          <div>
            <div className="text-sm font-bold text-yellow-400">Mercado hoje</div>
            <div className="text-[10px]">
                {loading && <span className="text-muted-foreground">Atualizando...</span>}
                {!loading && (
                  <span className="inline-flex items-center gap-1 rounded-full border border-red-500/30 bg-red-500/10 px-2 py-0.5 font-semibold text-red-400 shadow-[0_0_18px_rgba(239,68,68,0.25)]">
                    <span className="h-1.5 w-1.5 animate-pulse rounded-full bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.9)]" />
                    AO VIVO{updatedAt ? ` · ${updatedAt}` : ''}
                  </span>
                )}
              </div>
          </div>
        </div>

        {insights.best && (
          <div className="hidden h-full shrink-0 items-center gap-2 border-r border-border/70 px-4 text-xs lg:flex">
            <span className="text-muted-foreground">Melhor</span>
            <strong>{insights.best.symbol}</strong>
            <span className="text-emerald-400">▲ {formatChange(insights.best.change)}</span>
          </div>
        )}

        {insights.worst && (
          <div className="hidden h-full shrink-0 items-center gap-2 border-r border-border/70 px-4 text-xs xl:flex">
            <span className="text-muted-foreground">Maior queda</span>
            <strong>{insights.worst.symbol}</strong>
            <span className="text-red-400">▼ {formatChange(insights.worst.change)}</span>
          </div>
        )}

        <div className="min-w-0 flex-1 overflow-hidden">
          <div className="market-ticker-track flex min-w-max items-center">
            {marqueeItems.map((item, index) => {
              const change = Number(item.change || 0);
              const positive = change >= 0;

              return (
                <div
                  key={`${item.symbol}-${index}`}
                  className="group flex h-12 items-center gap-2 border-l border-border/60 px-5 text-sm transition-colors hover:bg-white/5"
                  title={item.name || item.symbol}
                >
                  <span className="font-bold text-foreground">{item.symbol}</span>
                  <span className="text-muted-foreground">
                    {item.price ? money(item.price) : 'Atualizando'}
                  </span>
                  <span className={positive ? 'font-semibold text-emerald-400' : 'font-semibold text-red-400'}>
                    {positive ? '▲' : '▼'} {formatChange(change)}
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  );
}
