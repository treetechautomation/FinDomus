export const dynamic = "force-dynamic";

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";

import { ShieldAlert, CreditCard, Landmark, Percent } from "lucide-react";
import { StatCard } from "@/components/overview/stat-card";
import { Badge } from "@/components/ui/badge";
import { getLiabilities, type Liability } from "@/services/firestore";
import { NewLiabilityDialog } from "@/components/passivos/new-liability-dialog";

export default async function PassivosPage() {
  // TODO: Replace 'test-user-id' with dynamic user ID after implementing auth
  const uid = 'test-user-id';
  let liabilities = await getLiabilities();

  const activeLiabilities = liabilities.filter((item) => {
    const total = Number(item.totalInstallments || 0);
    const current = Number(item.currentInstallment || 0);
    const balance = Number(item.remainingBalance || 0);
    return total > 0 && current < total && balance > 0;
  });

  
  const totalLiabilities = activeLiabilities.reduce((sum, item) => sum + Number(item.remainingBalance || 0), 0);

// 🧠 COMPROMETIMENTO MENSAL
const totalMonthlyCommitment = activeLiabilities.reduce(
  (sum, item) => sum + Number(item.installmentValue || 0),
  0
);

// 🧠 PROJEÇÃO FUTURA (nível Nubank)
function buildMonthlyProjection(liabilities: Liability[]) {
  const map: Record<string, number> = {};
  const now = new Date();

  liabilities.forEach((item) => {
    const remaining =
        Math.max(Number(item.totalInstallments || 0) - Number(item.currentInstallment || 0) + 1, 0);

    for (let i = 0; i < remaining; i++) {
      const d = new Date(now);
      d.setMonth(d.getMonth() + i);

      const key = `${d.getFullYear()}-${String(
        d.getMonth() + 1
      ).padStart(2, "0")}`;

      map[key] = (map[key] || 0) + Number(item.installmentValue || 0);
    }
  });

  return map;
}

const monthlyProjection = buildMonthlyProjection(activeLiabilities);

  return (
    <div className="space-y-6">
       <div>
          <h1 className="text-2xl md:text-3xl font-bold tracking-tight flex items-center gap-3">
            <ShieldAlert className="w-8 h-8 text-primary" />
            Passivos e Obrigações
          </h1>
          <p className="text-muted-foreground mt-1">Controle suas dívidas, financiamentos e parcelamentos.</p>
<div className="mt-3">
  <NewLiabilityDialog />
</div>
        </div>

      <Card>
        <CardHeader>
            <CardTitle>Resumo dos Passivos</CardTitle>
        </CardHeader>
        <CardContent className="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            <StatCard
                title="Total Comprometido"
                value={totalLiabilities.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                icon={ShieldAlert}
                variant="negative"
                description="Soma do saldo devedor de todas as obrigações."
            />
             <StatCard
                  title="Comprometimento Mensal"
                  value={totalMonthlyCommitment.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  icon={CreditCard}
                  description="Valor previsto em parcelas no mês atual."
              />
             <StatCard
                  title="Meses Projetados"
                  value={String(Object.keys(monthlyProjection).length)}
                  icon={Percent}
                  description="Quantidade de meses com parcelas futuras."
              />
        </CardContent>
      </Card>
      
        <Card>
          <CardHeader>
            <CardTitle>Previsão dos Próximos Meses</CardTitle>
            <CardDescription>
              Estimativa automática baseada nas parcelas restantes.
            </CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 md:grid-cols-3">
            {Object.entries(monthlyProjection).slice(0, 6).map(([month, value]) => {
              const [year, monthNumber] = month.split("-");
              const label = new Date(Number(year), Number(monthNumber) - 1, 1).toLocaleDateString("pt-BR", {
                month: "short",
                year: "numeric",
              });

              return (
                <div key={month} className="rounded-xl border bg-card/60 p-4">
                  <p className="text-sm text-muted-foreground capitalize">{label}</p>
                  <p className="mt-1 text-lg font-bold text-negative">
                    {value.toLocaleString("pt-BR", { style: "currency", currency: "BRL" })}
                  </p>
                </div>
              );
            })}
          </CardContent>
        </Card>

      <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {activeLiabilities.map((item) => {
            const remainingInstallments = Math.max(Number(item.totalInstallments || 0) - Number(item.currentInstallment || 0) + 1, 0);
            const progress = Number(item.totalInstallments || 0) > 0 ? (Number(item.currentInstallment || 0) / Number(item.totalInstallments || 0)) * 100 : 0;
              const progressColor =
                progress >= 80
                  ? "bg-emerald-500"
                  : progress >= 45
                    ? "bg-yellow-400"
                    : "bg-red-500";
            const endDate = new Date(item.createdAt || Date.now());
            endDate.setMonth(endDate.getMonth() + remainingInstallments);
            const endLabel = endDate.toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' });

            return (
          <Card key={item.id}>
            <CardHeader>
              <CardTitle className="flex items-center justify-between text-lg">
                {item.name}
                <Badge variant="outline">{item.type}</Badge>
              </CardTitle>
              <CardDescription className="flex items-center gap-2 pt-1">
                 {item.type === 'Cartão' ? <CreditCard className="w-4 h-4" /> : <Landmark className="w-4 h-4" />}
                 {item.institution}
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <div className="flex justify-between items-end mb-1">
                  <span className="text-lg font-bold text-negative">
                    {item.installmentValue.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  </span>
                  <span className="text-sm font-medium text-muted-foreground">
                    Faltam {remainingInstallments} • Parcela {item.currentInstallment}/{item.totalInstallments}
                  </span>
                </div>
                <Progress value={progress} className="h-2 bg-slate-800/80" indicatorClassName={progressColor} />
              </div>
              <div className="text-sm text-muted-foreground flex justify-between">
                <span>Saldo devedor:</span> 
                <span className="font-medium text-card-foreground">{Number(item.remainingBalance || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}</span>
              </div>
            </CardContent>
          </Card>
            );
          })}
      </div>
    </div>
  );
}
