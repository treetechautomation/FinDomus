'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import { X } from 'lucide-react';

import { addCategory, deleteCategory, updateCategory } from '@/services/firestore';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';

type Category = {
  id?: string;
  name: string;
  keywords?: string[];
};

export function CategoriesManager({ categories }: { categories: Category[] }) {
  const router = useRouter();
    const [name, setName] = useState('');
  const [saving, setSaving] = useState(false);
  const [deletingId, setDeletingId] = useState<string | null>(null);

  async function handleAdd(e: React.FormEvent<HTMLFormElement>) {
    e.preventDefault();

    const cleanName = name.trim();

    if (!cleanName) {
      alert('Informe o nome da categoria.');
      return;
    }

    const alreadyExists = categories.some(
      (category) => category.name.toLowerCase() === cleanName.toLowerCase()
    );

    if (alreadyExists) {
      alert('Essa categoria já existe.');
      return;
    }

    try {
      setSaving(true);
      await addCategory({ name: cleanName, keywords: [] });
      setName('');
      router.refresh();
    } catch (error) {
      console.error('Erro ao adicionar categoria:', error);
      alert('Não foi possível adicionar a categoria.');
    } finally {
      setSaving(false);
    }
  }

  async function handleDelete(category: Category) {
    if (!category.id) return;

    const ok = confirm(`Remover a categoria "${category.name}"?`);
    if (!ok) return;

    try {
      setDeletingId(category.id);
      await deleteCategory(category.id);
      router.refresh();
    } catch (error) {
      console.error('Erro ao remover categoria:', error);
      alert('Não foi possível remover a categoria.');
    } finally {
      setDeletingId(null);
    }
  }

  async function handleKeywordsBlur(category: Category, value: string) {
    if (!category.id) return;

    const keywords = value
      .split(',')
      .map((keyword) => keyword.trim().toLowerCase())
      .filter(Boolean);

    try {
      await updateCategory(category.id, { keywords });

      console.log('salvo');
      router.refresh();
    } catch (error) {
      console.error('Erro ao salvar keywords:', error);
      alert('Não foi possível salvar as keywords.');
    }
  }

  return (
    <>
      <div className="grid gap-3 mb-4 md:grid-cols-2">
        {categories.map((category) => (
          <div key={category.id ?? category.name} className="rounded-lg border p-3 space-y-2">
            <div className="flex items-center justify-between gap-2">
              <Badge variant="secondary" className="text-sm font-normal py-1 px-3">
                {category.name}
              </Badge>

              <Button
                type="button"
                variant="ghost"
                size="icon"
                className="h-8 w-8"
                disabled={!category.id || deletingId === category.id}
                onClick={() => handleDelete(category)}
              >
                <X className="h-4 w-4" />
              </Button>
            </div>

            <Input
              placeholder="keywords: nutag, pedagio, sem parar"
              defaultValue={(category.keywords || []).join(', ')}
              onBlur={(e) => handleKeywordsBlur(category, e.target.value)}
              disabled={!category.id}
            />
          </div>
        ))}

        {categories.length === 0 && (
          <div className="text-muted-foreground">Nenhuma categoria cadastrada ainda.</div>
        )}
      </div>

      <form onSubmit={handleAdd} className="flex gap-2">
        <Input
          placeholder="Nova categoria"
          value={name}
          onChange={(e) => setName(e.target.value)}
        />
        <Button type="submit" disabled={saving}>
          {saving ? 'Adicionando...' : 'Adicionar'}
        </Button>
      </form>
    </>
  );
}
