  'Ações Internacionais': 'Ações Internacionais',
  'FIIs': 'Fundos Imobiliários',
  'Fundos Imobiliários': 'Fundos Imobiliários',
  'Cripto': 'Criptomoedas',
  'Criptomoedas': 'Criptomoedas',
  'REITs': 'REITs',
  'Renda Fixa': 'Renda Fixa',
  'Renda Fixa Internacional': 'Renda Fixa Internacional',
