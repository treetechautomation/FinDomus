import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";
import { installments } from "@/lib/data";
import { CreditCard, ShoppingBag } from "lucide-react";

export default function ParcelasPage() {
  const getInstallmentProgress = (current: number, total: number) => {
    return (current / total) * 100;
  };

  return (
    <div className="space-y-6">
      <h1 className="text-2xl md:text-3xl font-bold tracking-tight">Controle de Parcelas</h1>
      
      <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {installments.map((item) => (
          <Card key={item.id}>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <ShoppingBag className="w-5 h-5 text-muted-foreground" />
                {item.purchaseName}
              </CardTitle>
              <CardDescription className="flex items-center gap-2 pt-1">
                 <CreditCard className="w-4 h-4" />
                 {item.card}
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <div className="flex justify-between items-end mb-1">
                  <span className="text-lg font-bold text-primary">
                    {item.installmentValue.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  </span>
                  <span className="text-sm font-medium text-muted-foreground">
                    Parcela {item.currentInstallment}/{item.totalInstallments}
                  </span>
                </div>
                <Progress value={getInstallmentProgress(item.currentInstallment, item.totalInstallments)} />
              </div>
              <div className="text-sm text-muted-foreground">
                Saldo restante: {item.remainingBalance.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  );
}
