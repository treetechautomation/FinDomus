export async function saveInvestmentGoals(goals: any[]) {
  const ref = doc(db, "settings", "investment_goals");
  await setDoc(ref, {
    goals,
    updatedAt: new Date().toISOString(),
  }, { merge: true });
}

export async function getInvestmentGoals() {
  const ref = doc(db, "settings", "investment_goals");
  const snap = await getDoc(ref);

  return snap.exists() ? snap.data().goals || [] : [];
}
