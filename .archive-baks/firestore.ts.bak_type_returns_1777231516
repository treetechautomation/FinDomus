export type TransactionDTO = {
  id?: string;
  accountId?: string;
  companyId?: string | null;
  type: "income" | "expense" | "transfer";
  amount: number;
  category?: string;
  description: string;
  date?: string;
  owner: "PF" | "PJ";
  merchant?: string;
  importHash?: string;
  createdAt?: string;
  updatedAt?: string;
};

function normalizeHashText(value: string) {
  return String(value || "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim()
    .toLowerCase()
    .replace(/\s+/g, " ");
}

export function generateImportHash(data: {
  date?: string;
  amount: number;
  description: string;
  merchant?: string;
  owner?: "PF" | "PJ";
}) {
  const base = [
    data.owner || "PF",
    data.date || "",
    Number(data.amount || 0).toFixed(2),
    normalizeHashText(data.description),
    normalizeHashText(data.merchant || ""),
  ].join("|");

  let hash = 0;
  for (let i = 0; i < base.length; i++) {
    hash = (hash << 5) - hash + base.charCodeAt(i);
    hash |= 0;
  }

  return `imp_${Math.abs(hash)}`;
}

export async function addTransaction(data: TransactionDTO) {
  const now = new Date().toISOString();
  const normalized: TransactionDTO = {
    ...data,
    companyId: data.companyId ?? null,
    date: data.date ?? now,
    createdAt: data.createdAt ?? now,
    updatedAt: data.updatedAt ?? now,
    merchant: data.merchant ?? "",
    importHash: data.importHash ?? generateImportHash(data),
  };

  const docRef = await addDoc(collection(db, "transactions"), normalized);

  return docRef.id;
}

export async function addTransactionsBatch(items: TransactionDTO[]) {
  const now = new Date().toISOString();
  const validItems = items
    .map((item) => ({
      ...item,
      owner: item.owner ?? "PF",
      companyId: item.companyId ?? null,
      date: item.date ?? now,
      createdAt: item.createdAt ?? now,
      updatedAt: item.updatedAt ?? now,
      merchant: item.merchant ?? "",
      importHash: item.importHash ?? generateImportHash(item),
    }))
    .filter((item) => item.description && Number.isFinite(Number(item.amount)));

  if (!validItems.length) {
    return { inserted: 0, skipped: 0, duplicates: [] as TransactionDTO[] };
  }

  const uniqueByHash = new Map<string, TransactionDTO>();

  for (const item of validItems) {
    if (item.importHash && !uniqueByHash.has(item.importHash)) {
      uniqueByHash.set(item.importHash, item);
    }
  }

  const uniqueItems = Array.from(uniqueByHash.values());
  const existingHashes = new Set<string>();

  for (const item of uniqueItems) {
    if (!item.importHash) continue;

    const q = query(
      collection(db, "transactions"),
      where("owner", "==", item.owner),
      where("importHash", "==", item.importHash)
    );

    const snap = await getDocs(q);

    if (!snap.empty) {
      existingHashes.add(item.importHash);
    }
  }

  const toInsert = uniqueItems.filter((item) => !existingHashes.has(item.importHash || ""));
  const batch = writeBatch(db);

  for (const item of toInsert) {
    const ref = doc(collection(db, "transactions"));
    batch.set(ref, item);
  }

  if (toInsert.length) {
    await batch.commit();
  }

  return {
    inserted: toInsert.length,
    skipped: validItems.length - toInsert.length,
    duplicates: uniqueItems.filter((item) => existingHashes.has(item.importHash || "")),
  };
}

export async function getAccountsWithBalance(): Promise<Account[]> {
  const accounts = await getAccounts();
  const transactions = await getTransactions();

  return accounts.map((account) => {
    const accountTransactions = transactions.filter(
      (transaction: any) => transaction.accountId === account.id
    );

    const transactionBalance = accountTransactions.reduce((total: number, transaction: any) => {
      const amount = Number(transaction.amount || 0);

      if (transaction.type === "income") return total + amount;
      if (transaction.type === "expense") return total - Math.abs(amount);

      return total;
    }, 0);

    return {
      ...account,
      balance: Number(account.balance || 0) + transactionBalance,
    };
  });
}

