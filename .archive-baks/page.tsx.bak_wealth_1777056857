
'use client';

import { useState } from 'react';
import { simulateCompound, generateChartData } from '@/core/finance/million';

import {
  LineChart,
  Line,
  XAxis,
  YAxis,
  Tooltip,
  ResponsiveContainer,
} from 'recharts';

export default function PrimeiroMilhao() {
  const [initial, setInitial] = useState(10000);
  const [rate, setRate] = useState(8);
  const [target, setTarget] = useState(1000000);

  const aportes = [50, 100, 200, 300, 400, 500, 1000];

const chartData = generateChartData({
  initial,
  rate: rate / 100,
});
  const anos = [10, 15, 20, 25, 30, 35, 40];

  return (
    <div className="space-y-6">
      <h1 className="text-2xl font-bold">Primeiro Milhão</h1>

      <div className="grid md:grid-cols-4 gap-4">
        <input value={rate} onChange={e => setRate(Number(e.target.value))} className="p-2 bg-black border" />
        <input value={initial} onChange={e => setInitial(Number(e.target.value))} className="p-2 bg-black border" />
        <input value={target} onChange={e => setTarget(Number(e.target.value))} className="p-2 bg-black border" />
      </div>

      <div className="overflow-auto">
        <table className="w-full text-sm">
          <thead>
            <tr>
              <th>Aporte</th>
              {anos.map(a => <th key={a}>{a} anos</th>)}
            </tr>
          </thead>
          <tbody>
            {aportes.map(aporte => (
              <tr key={aporte}>
                <td>R$ {aporte}</td>
                {anos.map(a => {
                  const total = simulateCompound({
                    initial,
                    monthly: aporte,
                    rate: rate / 100,
                    years: a,
                  });

                  return (
                    <td key={a} className={total >= target ? 'text-green-500' : ''}>
                      {total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

<div className="h-[400px] bg-black/40 p-4 rounded-xl">
  <ResponsiveContainer width="100%" height="100%">
    <LineChart data={chartData}>
      <XAxis dataKey="year" />
      <YAxis />
      <Tooltip />

      
      <Line
        type="monotone"
        dataKey="50"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="100"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="200"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="300"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="400"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="500"
        strokeWidth={2}
      />
      <Line
        type="monotone"
        dataKey="1000"
        strokeWidth={2}
      />

    </LineChart>
  </ResponsiveContainer>
</div>

</div>
  );
}
