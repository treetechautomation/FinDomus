const CATEGORY_PJ = [
  'Serviços Prestados',
  'Vendas',
  'Contratos Recorrentes',
  'Consultoria',
  'Outros Recebimentos',

  'Ferramentas / Software',
  'Internet / Telefonia',
  'Equipamentos',
  'Marketing / Ads',
  'Despesas Administrativas',

  'Pró-labore',
  'Salários',
  'Freelancers',
  'Benefícios',

  'DAS (Simples Nacional)',
  'INSS',
