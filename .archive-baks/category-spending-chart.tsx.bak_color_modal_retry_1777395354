'use client';

import {
  ChartContainer,
  ChartTooltip,
  ChartTooltipContent,
  ChartConfig,
} from '@/components/ui/chart';

import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from '@/components/ui/dialog';
import { PieChart, Pie, Cell } from 'recharts';
import { useRouter } from 'next/navigation';
import { useState, useEffect } from 'react';

type Props = {
  data: { name: string; value: number }[];
  selectedCategory?: string;
  month: number;
  mode: string;
};

const DEFAULT_COLORS = [
  '#00D0E6',
  '#22C55E',
  '#6366F1',
  '#F59E0B',
  '#EF4444',
  '#8B5CF6',
];

export function CategorySpendingChart({ data, selectedCategory = '', month, mode }: Props) {
  const router = useRouter();

  const activeCategory = selectedCategory || null;

  const [colorMap, setColorMap] = useState<Record<string, string>>({});

  useEffect(() => {
    const saved = localStorage.getItem('categoryColors');
    if (saved) setColorMap(JSON.parse(saved));
  }, []);

  function updateColor(name: string, color: string) {
    const next = { ...colorMap, [name]: color };
    setColorMap(next);
    localStorage.setItem('categoryColors', JSON.stringify(next));
  }

  function toggleCategory(category: string) {
    const nextCategory = category === activeCategory ? '' : category;
    const url = nextCategory
      ? `/pessoal?month=${month}&mode=${mode}&page=1&category=${encodeURIComponent(nextCategory)}`
      : `/pessoal?month=${month}&mode=${mode}&page=1`;

    router.push(url);
  }

  const total = data.reduce((sum, item) => sum + item.value, 0);

  const enriched = data.map((item, index) => ({
    ...item,
    percent: total > 0 ? (item.value / total) * 100 : 0,
    fill: colorMap[item.name] || DEFAULT_COLORS[index % DEFAULT_COLORS.length],
  }));

  const chartConfig: ChartConfig = {
    value: { label: 'Gasto' },
  };

  return (
    <Card>
      <CardHeader>
        <CardTitle>Gastos por Categoria</CardTitle>
      </CardHeader>

      <CardContent className="flex flex-col items-center gap-4">
        <ChartContainer
          config={chartConfig}
            className="h-[380px] w-full max-w-[560px]"
        >
          <PieChart>
            <ChartTooltip
              content={
                <ChartTooltipContent
                  formatter={(value: any) =>
                    Number(value).toLocaleString('pt-BR', {
                      style: 'currency',
                      currency: 'BRL',
                    })
                  }
                />
              }
            />

            <Pie
              data={enriched}
              dataKey="value"
              nameKey="name"
                innerRadius={105}
                outerRadius={175}
              strokeWidth={4}
              onClick={(entry: any) =>
                toggleCategory(entry.name)
              }
            >
              {enriched.map((entry) => (
                <Cell
                  key={entry.name}
                  fill={entry.fill}
                  opacity={
                    activeCategory && activeCategory !== entry.name ? 0.3 : 1
                  }
                />
              ))}
            </Pie>
          </PieChart>
        </ChartContainer>
</CardContent>
    </Card>
  );
}
