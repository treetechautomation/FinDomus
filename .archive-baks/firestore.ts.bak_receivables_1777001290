export async function getTransactions() {
  const snap = await getDocs(collection(db, "transactions"));

  return snap.docs.map((doc) => ({
    id: doc.id,
    ...doc.data(),
  }));
}

export async function getPersonalTransactions(uid?: string) {
  const data = await getTransactions();
  return data.filter((item: any) => item.owner === "PF");
}

export async function addTransaction(data: {
  accountId?: string;
  companyId?: string | null;
  type: "income" | "expense" | "transfer";
  amount: number;
  category?: string;
  description: string;
  date?: string;
  owner: "PF" | "PJ";
}) {
  const docRef = await addDoc(collection(db, "transactions"), {
    ...data,
    companyId: data.companyId ?? null,
    date: data.date ?? new Date().toISOString(),
    createdAt: new Date().toISOString(),
  });

  return docRef.id;
}

export async function getAccountsWithBalance(): Promise<Account[]> {
  const accounts = await getAccounts();
  const transactions = await getTransactions();

  return accounts.map((account) => {
    const accountTransactions = transactions.filter(
      (transaction: any) => transaction.accountId === account.id
    );

    const transactionBalance = accountTransactions.reduce((total: number, transaction: any) => {
      const amount = Number(transaction.amount || 0);

      if (transaction.type === "income") return total + amount;
      if (transaction.type === "expense") return total - Math.abs(amount);

      return total;
    }, 0);

    return {
      ...account,
      balance: Number(account.balance || 0) + transactionBalance,
    };
  });
}

export async function updateAccount(
  accountId: string,
  data: {
    name?: string;
    type?: string;
    owner?: "PF" | "PJ";
    companyId?: string | null;
    balance?: number;
  }
) {
  const ref = doc(db, "accounts", accountId);
  await updateDoc(ref, data);
}

