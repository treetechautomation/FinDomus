
import { NextRequest, NextResponse } from 'next/server';
import { execFile as execFileCb } from 'child_process';
import { writeFile, readFile, unlink } from 'fs/promises';
import { tmpdir } from 'os';
import { join } from 'path';
import { randomUUID } from 'crypto';
import { promisify } from 'util';

import { extractTextFromPDF } from '@/core/finance/pdf-reader';

const execFile = promisify(execFileCb);
export const runtime = 'nodejs';
export const dynamic = 'force-dynamic';

async function isQpdfAvailable(): Promise<boolean> {
  try {
    await execFile('qpdf', ['--version']);
    return true;
  } catch (error) {
    return false;
  }
}

export async function POST(req: NextRequest) {
  const tempFiles: string[] = [];

  try {
    const qpdfAvailable = await isQpdfAvailable();
    if (!qpdfAvailable) {
      return NextResponse.json(
        {
          code: 'QPDF_NOT_AVAILABLE',
          error: 'O utilitário qpdf não está disponível no ambiente do servidor para descriptografar PDFs.',
        },
        { status: 500 }
      );
    }
    
    const formData = await req.formData();
    const file = formData.get('file') as File | null;
    const password = formData.get('password') as string | null;

    if (!file) {
      return NextResponse.json({ error: 'Arquivo não enviado' }, { status: 400 });
    }

    const arrayBuffer = await file.arrayBuffer();
    const originalBuffer = Buffer.from(arrayBuffer);
    
    let bufferToParse = originalBuffer;
    let passwordForReader: string | undefined = password || undefined;

    if (password) {
      const tempInputPath = join(tmpdir(), `${randomUUID()}.pdf`);
      const tempOutputPath = join(tmpdir(), `${randomUUID()}.pdf`);
      tempFiles.push(tempInputPath, tempOutputPath);

      await writeFile(tempInputPath, originalBuffer);

      try {
        await execFile('qpdf', ['--password=' + password, '--decrypt', tempInputPath, tempOutputPath]);
        bufferToParse = await readFile(tempOutputPath);
        passwordForReader = undefined; // PDF is decrypted, password no longer needed for the next step
      } catch (qpdfError: any) {
        // qpdf exits with code 3 for password errors
        if (qpdfError.code === 3 || qpdfError.stderr?.includes('password')) {
            return NextResponse.json(
              {
                code: 'PDF_PASSWORD_REQUIRED',
                error: 'Este PDF está protegido ou a senha informada está incorreta. Informe a senha do PDF e tente novamente.',
              },
              { status: 423 }
            );
        }
        // For other qpdf errors
        throw new Error(`Erro ao executar qpdf: ${qpdfError.message}`);
      }
    }
    
    const text = await extractTextFromPDF(bufferToParse, passwordForReader);

    return NextResponse.json({ text });
  } catch (error) {
    const message = error instanceof Error ? error.message : 'Erro ao processar PDF';

    if (message.includes('PDF_PROTEGIDO_OU_SENHA_INVALIDA') || message.includes('PDF_PASSWORD_REQUIRED')) {
      return NextResponse.json(
        {
          code: 'PDF_PASSWORD_REQUIRED',
          error: 'Este PDF está protegido ou a senha informada está incorreta. Informe a senha do PDF e tente novamente.',
        },
        { status: 423 }
      );
    }

    if (message.includes('PDF_SEM_TEXTO_EXTRAIVEL')) {
      return NextResponse.json(
        {
          code: 'PDF_NO_TEXT',
          error: 'Não consegui extrair texto deste PDF. Ele pode ser uma imagem/scan. Use CSV/OFX ou tente outro arquivo.',
        },
        { status: 422 }
      );
    }

    console.error('Erro ao processar PDF:', error);
    return NextResponse.json({ error: message }, { status: 500 });
  } finally {
    // Cleanup temporary files
    for (const path of tempFiles) {
      try {
        await unlink(path);
      } catch (cleanupError) {
        console.error(`Falha ao apagar arquivo temporário ${path}:`, cleanupError);
      }
    }
  }
}
