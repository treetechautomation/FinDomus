export function parseOFX(text: string) {
  const transactions = [];

  const blocks = text.split('<STMTTRN>').slice(1);

  for (const block of blocks) {
    const get = (tag: string) => {
      const match = block.match(new RegExp(`<${tag}>([^<]+)`));
      return match ? match[1].trim() : '';
    };

    const typeRaw = get('TRNTYPE');
    const amount = parseFloat(get('TRNAMT') || '0');
    const dateRaw = get('DTPOSTED');
    const description = get('MEMO');

    const date = dateRaw
      ? `${dateRaw.slice(6,8)}/${dateRaw.slice(4,6)}/${dateRaw.slice(0,4)}`
      : '';

    const type = amount < 0 ? 'expense' : 'income';

    transactions.push({
      date,
      description,
      amount,
      category: 'Outros',
      merchant: extractMerchant(description),
      type,
    });
  }

  return transactions;
}

function extractMerchant(desc: string) {
  if (!desc) return '';

  const clean = desc
    .replace(/pix|transferencia|pagamento/gi, '')
    .trim();

  return clean.split(' ').slice(0, 3).join(' ');
}
