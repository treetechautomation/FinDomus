'use client';

import {
  ChartContainer,
  ChartTooltip,
  ChartTooltipContent,
  ChartConfig,
} from '@/components/ui/chart';

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { PieChart, Pie, Cell } from 'recharts';

type Props = {
  data: any[];
};

const COLORS = ['#22C55E', '#00D0E6'];

export function RevenueChartPanel({ data }: Props) {
  const rows = ['Recebimentos', 'Serviços prestados'].map((category) => ({
    name: category,
    value: data
      .filter((t) => String(t.category || '') === category)
      .reduce((sum, t) => sum + Number(t.amount || 0), 0),
  })).filter((item) => item.value > 0);

  const chartConfig: ChartConfig = {
    value: { label: 'Receita' },
  };

  return (
    <Card>
      <CardHeader>
        <CardTitle>Receitas por Tipo</CardTitle>
        <CardDescription>
          Distribuição entre recebimentos e serviços prestados.
        </CardDescription>
      </CardHeader>

      <CardContent className="flex flex-col items-center gap-4">
        <ChartContainer config={chartConfig} className="h-[300px] w-full max-w-[420px]">
          <PieChart>
            <ChartTooltip
              content={
                <ChartTooltipContent
                  formatter={(value: any, name: any) => [
                    Number(value).toLocaleString('pt-BR', {
                      style: 'currency',
                      currency: 'BRL',
                    }),
                    String(name || 'Categoria'),
                  ]}
                />
              }
            />

            <Pie data={rows} dataKey="value" nameKey="name" innerRadius={80} outerRadius={120}>
              {rows.map((entry, index) => (
                <Cell key={entry.name} fill={COLORS[index % COLORS.length]} />
              ))}
            </Pie>
          </PieChart>
        </ChartContainer>

        <div className="w-full space-y-2">
          {rows.map((item) => (
            <div key={item.name} className="flex items-center justify-between text-sm">
              <span>{item.name}</span>
              <strong>
                {Number(item.value).toLocaleString('pt-BR', {
                  style: 'currency',
                  currency: 'BRL',
                })}
              </strong>
            </div>
          ))}
        </div>
      </CardContent>
    </Card>
  );
}
