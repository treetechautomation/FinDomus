'use client';

import { useMemo, useState } from 'react';
import { CartesianGrid, Line, LineChart, ReferenceLine, ResponsiveContainer, Tooltip, XAxis, YAxis } from 'recharts';
import { PiggyBank } from 'lucide-react';
import { CalculatorField } from '@/components/finance/calculator-field';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

function brl(v: number) {
  return Number(v || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
}

export default function AposentadoriaPage() {
  const [currentAge, setCurrentAge] = useState('35');
  const [retireAge, setRetireAge] = useState('65');
  const [currentAmount, setCurrentAmount] = useState('50000');
  const [targetIncome, setTargetIncome] = useState('6000');
  const [rate, setRate] = useState('8');
  const [result, setResult] = useState<any>(null);

  const years = Math.max(Number(retireAge) - Number(currentAge), 1);
  const targetAmount = Number(targetIncome) * 300;

  const data = useMemo(() => {
    const monthly = result?.monthly ?? 0;
    let total = Number(currentAmount || 0);
    const r = Number(rate || 0) / 100 / 12;
    return Array.from({ length: years + 1 }).map((_, year) => {
      if (year > 0) for (let i = 0; i < 12; i++) total = total * (1 + r) + monthly;
      return { age: Number(currentAge) + year, total };
    });
  }, [result, currentAmount, rate, years, currentAge]);

  function calculate() {
    const r = Number(rate) / 100 / 12;
    const n = years * 12;
    const needed = r > 0
      ? (targetAmount - Number(currentAmount) * Math.pow(1 + r, n)) / ((Math.pow(1 + r, n) - 1) / r)
      : (targetAmount - Number(currentAmount)) / n;

    setResult({ monthly: Math.max(needed, 0), targetAmount, years, risk: needed > Number(targetIncome) * 0.3 });
  }

  return (
    <div className="space-y-8">
      <div>
        <div className="text-sm text-muted-foreground">Investimentos › Calculadoras</div>
        <h1 className="mt-2 text-3xl font-bold tracking-tight">Simulador de aposentadoria</h1>
        <p className="text-muted-foreground">Planeje sua renda futura e veja o aporte mensal necessário.</p>
      </div>

      <Card className="border-primary/20 bg-card/70">
        <CardHeader>
          <CardTitle className="flex items-center gap-2"><PiggyBank className="h-5 w-5 text-primary" /> Parâmetros da simulação</CardTitle>
          <CardDescription>Modelo patrimonial para renda futura. Patrimônio alvo = renda mensal desejada × 300.</CardDescription>
        </CardHeader>
        <CardContent className="grid gap-4 lg:grid-cols-6">
          <CalculatorField label="Idade atual" value={currentAge} onChange={setCurrentAge} />
          <CalculatorField label="Idade alvo" value={retireAge} onChange={setRetireAge} />
          <CalculatorField label="Patrimônio atual" prefix="R$" value={currentAmount} onChange={setCurrentAmount} />
          <CalculatorField label="Renda desejada" prefix="R$" value={targetIncome} onChange={setTargetIncome} />
          <CalculatorField label="Taxa anual" suffix="%" value={rate} onChange={setRate} />
          <div className="flex items-end"><Button onClick={calculate} className="h-11 w-full">Calcular</Button></div>
        </CardContent>
      </Card>

      {result && (
        <div className="grid gap-4 lg:grid-cols-3">
          <Card><CardHeader><CardTitle>Patrimônio alvo</CardTitle></CardHeader><CardContent className="text-2xl font-bold">{brl(result.targetAmount)}</CardContent></Card>
          <Card className="border-emerald-500/30"><CardHeader><CardTitle>Aporte necessário</CardTitle></CardHeader><CardContent className="text-2xl font-bold text-emerald-500">{brl(result.monthly)}</CardContent></Card>
          <Card className={result.risk ? 'border-destructive/40' : 'border-emerald-500/30'}><CardHeader><CardTitle>Diagnóstico</CardTitle></CardHeader><CardContent className={result.risk ? 'text-sm text-destructive' : 'text-sm text-emerald-500'}>{result.risk ? 'Aporte alto em relação à renda desejada. Revise prazo, meta ou padrão de gastos.' : 'Plano sustentável dentro do prazo informado.'}</CardContent></Card>
        </div>
      )}

      <Card>
        <CardHeader><CardTitle>Curva até a aposentadoria</CardTitle><CardDescription>Linha amarela representa o patrimônio alvo.</CardDescription></CardHeader>
        <CardContent className="h-[360px]">
          <ResponsiveContainer width="100%" height="100%">
            <LineChart data={data}>
              <CartesianGrid strokeDasharray="3 3" opacity={0.25} />
              <XAxis dataKey="age" />
              <YAxis tickFormatter={(v) => brl(Number(v)).replace(',00', '')} />
              <Tooltip formatter={(v: any) => brl(Number(v))} labelFormatter={(v) => `Idade ${v}`} />
              <ReferenceLine y={targetAmount} stroke="#eab308" strokeDasharray="4 4" />
              <Line type="monotone" dataKey="total" stroke="#a855f7" strokeWidth={3} dot={{ r: 3 }} />
            </LineChart>
          </ResponsiveContainer>
        </CardContent>
      </Card>
    </div>
  );
}
