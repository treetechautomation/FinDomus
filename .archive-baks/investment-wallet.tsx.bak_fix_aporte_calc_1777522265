            <CardHeader>
              <CardTitle>
    Total: {(() => {
      const total = goals.reduce((sum, g) => sum + g.value, 0);
      return <span className={total === 100 ? 'text-emerald-400' : 'text-red-400'}>{total}%</span>;
    })()}
  </CardTitle>
            </CardHeader>
            <CardContent className="space-y-2">
              {goals.map((goal, index) => (
                <div key={goal.name} className="flex items-center justify-between text-sm">
                  <span>{goal.name}</span>
                  <strong className="text-yellow-400">{goal.value}%</strong>
                </div>
              ))}
            </CardContent>
          </Card>

          <Card>
            <CardContent className="space-y-8 p-6">
              {goals.map((goal) => (
                <div key={goal.name} className="space-y-3">
                  <div className="flex justify-between">
                    <h3 className="text-xl font-bold">{goal.name}</h3>
                    <span>{goal.value}%</span>
                  </div>
                  <Slider
                      value={[goal.value]}
                      min={0}
                      max={100}
                      step={1}
                      onValueChange={(val) => {
                        const newGoals = [...goals];
                        const index = newGoals.findIndex((g) => g.name === goal.name);
                        newGoals[index].value = val[0];

                        const total = newGoals.reduce((sum, g) => sum + g.value, 0);

                        if (total <= 100) {
                          setGoals(newGoals);
                        }
                      }}
                    />
                  <div className="flex justify-between text-sm">
                    <span>0%</span>
                    <span>100%</span>
                  </div>
                </div>
              ))}
            </CardContent>
          </Card>
        </div>

        <div className="flex justify-center gap-4">
          <Button variant="outline" className="w-56" onClick={handleResetGoals}>Resetar valores</Button>
          <Button className="w-56" onClick={handleSaveGoals}>Salvar</Button>
        </div>
      </TabsContent>

        <TabsContent value="aportar" className="space-y-6">
          <div>
            <h2 className="text-3xl font-bold">Novo Aporte</h2>
            <p className="text-muted-foreground">
              Informe o valor do aporte e o sistema sugere a distribuição ideal para aproximar sua carteira das metas.
            </p>
