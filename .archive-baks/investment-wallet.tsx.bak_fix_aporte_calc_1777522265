                    <td className="p-3 text-center">
                      <Button size="sm" className="bg-yellow-500 text-black hover:bg-yellow-400">
                        <Edit className="mr-2 h-4 w-4" />
                        Editar
                      </Button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </CardContent>
        </Card>
      </TabsContent>
    </Tabs>
  );
}
