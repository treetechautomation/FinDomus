                    </Pie>
                  </PieChart>
                </ResponsiveContainer>
              </div>

              <div className="text-center -mt-32 mb-20 pointer-events-none">
                <div className="text-sm">{money(total)}</div>
                <div className="font-bold">Total</div>
              </div>

              <div className="space-y-2">
                {distribution.map((item) => (
                  <div key={item.name} className="flex items-center justify-between text-sm">
                    <span className="flex items-center gap-2">
                      <span className="h-3 w-3 rounded-full" style={{ background: item.color }} />
                      {item.name}
                    </span>
                    <strong className="text-yellow-400">{item.percent.toFixed(2)}%</strong>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        </div>

        <p className="text-sm text-muted-foreground">
          * Atenção: ativos sem preço atual ou valor atual entram com valor zero no cálculo da carteira.
        </p>
      </TabsContent>

      <TabsContent value="metas" className="space-y-6">
        <div>
          <h2 className="text-3xl font-bold">Metas de Investimento</h2>
          <p className="text-muted-foreground">Edite os itens abaixo para ajustar suas metas.</p>
        </div>

          <div className="grid gap-4 md:grid-cols-3">
            {(['Conservador', 'Moderado', 'Arrojado'] as const).map((profile) => (
              <button
                key={profile}
                type="button"
                onClick={() => applyInvestmentProfile(profile)}
                className={`rounded-xl border text-left transition-all hover:border-yellow-500/60 hover:bg-yellow-500/5 ${selectedProfile === profile ? 'border-yellow-500/80 bg-yellow-500/10 shadow-[0_0_24px_rgba(234,179,8,0.12)]' : 'border-border bg-card'}`}
              >
                <Card className="border-0 bg-transparent shadow-none">
                  <CardContent className="p-5">
                    <h3 className="font-bold">{profile}</h3>
                    <p className="mt-2 text-xs text-muted-foreground">
