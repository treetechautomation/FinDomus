'use client';

import { useState } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';

function brl(v: number) {
  return Number(v || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
}

export default function AposentadoriaPage() {
  const [currentAge, setCurrentAge] = useState(35);
  const [retireAge, setRetireAge] = useState(65);
  const [currentAmount, setCurrentAmount] = useState(50000);
  const [targetIncome, setTargetIncome] = useState(6000);
  const [rate, setRate] = useState(8);
  const [result, setResult] = useState<any>(null);

  function calculate() {
    const years = Math.max(retireAge - currentAge, 1);
    const targetAmount = targetIncome * 300;
    const r = rate / 100 / 12;
    const n = years * 12;
    const needed = r > 0
      ? (targetAmount - currentAmount * Math.pow(1 + r, n)) / ((Math.pow(1 + r, n) - 1) / r)
      : (targetAmount - currentAmount) / n;

    setResult({
      years,
      targetAmount,
      monthly: Math.max(needed, 0),
      risk: needed > targetIncome * 0.3,
    });
  }

  return (
    <div className="space-y-6">
      <h1 className="text-3xl font-bold">Simulador de aposentadoria</h1>
      <Card>
        <CardHeader>
          <CardTitle>Planejamento de renda futura</CardTitle>
          <CardDescription>Calcula o patrimônio alvo e o aporte mensal necessário.</CardDescription>
        </CardHeader>
        <CardContent className="grid gap-4 md:grid-cols-6">
          <input className="rounded-md border bg-background p-3" type="number" value={currentAge} onChange={(e) => setCurrentAge(Number(e.target.value))} placeholder="Idade atual" />
          <input className="rounded-md border bg-background p-3" type="number" value={retireAge} onChange={(e) => setRetireAge(Number(e.target.value))} placeholder="Idade alvo" />
          <input className="rounded-md border bg-background p-3" type="number" value={currentAmount} onChange={(e) => setCurrentAmount(Number(e.target.value))} placeholder="Patrimônio atual" />
          <input className="rounded-md border bg-background p-3" type="number" value={targetIncome} onChange={(e) => setTargetIncome(Number(e.target.value))} placeholder="Renda desejada" />
          <input className="rounded-md border bg-background p-3" type="number" value={rate} onChange={(e) => setRate(Number(e.target.value))} placeholder="Taxa anual %" />
          <Button onClick={calculate}>Calcular</Button>
        </CardContent>
      </Card>

      {result && (
        <Card className={result.risk ? 'border-destructive/40' : 'border-emerald-500/30'}>
          <CardHeader><CardTitle>Diagnóstico patrimonial</CardTitle></CardHeader>
          <CardContent className="space-y-2">
            <div>Patrimônio alvo: <b>{brl(result.targetAmount)}</b></div>
            <div>Aporte mensal necessário: <b>{brl(result.monthly)}</b></div>
            <div>Prazo: <b>{result.years} anos</b></div>
            {result.risk && <div className="text-destructive font-semibold">⚠️ Aporte necessário alto. Revise prazo, renda desejada ou padrão de gastos.</div>}
          </CardContent>
        </Card>
      )}
    </div>
  );
}
