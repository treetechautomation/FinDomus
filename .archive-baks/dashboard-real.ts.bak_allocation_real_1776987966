import { getAccountsWithBalance } from '@/services/firestore';
import { getTransactions } from '@/services/firestore';

function getLastSixMonthsFlow(transactions: any[]) {
  const now = new Date();

  const months = Array.from({ length: 6 }).map((_, index) => {
    const d = new Date(now.getFullYear(), now.getMonth() - (5 - index), 1);
    return {
      month: d.toLocaleDateString('pt-BR', { month: 'short' }).replace('.', ''),
      monthIndex: d.getMonth(),
      year: d.getFullYear(),
      income: 0,
      expenses: 0,
    };
  });

  for (const transaction of transactions) {
    const d = new Date(transaction.date || transaction.createdAt);
    const bucket = months.find(
      (item) => item.monthIndex === d.getMonth() && item.year === d.getFullYear()
    );

    if (!bucket) continue;

    const amount = Number(transaction.amount || 0);

    if (transaction.type === 'income') {
      bucket.income += amount;
    }

    if (transaction.type === 'expense') {
      bucket.expenses += Math.abs(amount);
    }
  }

  return months.map(({ month, income, expenses }) => ({
    month,
    income,
    expenses,
  }));
}

export async function getDashboardReal() {
  const accounts = await getAccountsWithBalance();
  const transactions = await getTransactions();

  // ===== SALDOS =====
  const totalPF = accounts
    .filter((a: any) => a.owner === 'PF')
    .reduce((sum: number, a: any) => sum + (a.balance || 0), 0);

  const totalPJ = accounts
    .filter((a: any) => a.owner === 'PJ')
    .reduce((sum: number, a: any) => sum + (a.balance || 0), 0);

  const total = totalPF + totalPJ;

  // ===== MÊS ATUAL =====
  const now = new Date();
  const currentMonth = now.getMonth();
  const currentYear = now.getFullYear();

  const monthTx = transactions.filter((t: any) => {
    const d = new Date(t.date || t.createdAt);
    return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
  });

  const income = monthTx
    .filter((t: any) => t.type === 'income')
    .reduce((sum: number, t: any) => sum + Number(t.amount || 0), 0);

  const expenses = monthTx
    .filter((t: any) => t.type === 'expense')
    .reduce((sum: number, t: any) => sum + Number(t.amount || 0), 0);

  const balance = income - expenses;

  return {
    totalPF,
    totalPJ,
    total,
    monthly: {
      income,
      expenses,
      balance,
    },
    monthlyFlow: getLastSixMonthsFlow(transactions),
  };
}
