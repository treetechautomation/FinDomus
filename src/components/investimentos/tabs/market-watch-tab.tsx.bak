  CVBI11: 'CVI Imóveis',
  HSML11: 'HSI Mall',
  HCTR11: 'HCTR11',
  HGLG11: 'HGLG11',
  VINO11: 'Vino Partners',
  VISC11: 'VISC11',
  BTLG11: 'BTLG11',
  XPML11: 'XP Malls',
  RBRF11: 'RBR Properties',

  ITUB4: 'Itaú Unibanco',
  ITUB3: 'Itaú Unibanco',
