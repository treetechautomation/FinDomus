rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funcoes auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isAuthenticated() && (request.auth.uid == userId || request.auth.token.admin == true);
    }

    function isMemberOfHousehold(householdId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/household_members/$(householdId + '_' + request.auth.uid));
    }

    function isHouseholdOwnerOrAdmin(householdId) {
      return isMemberOfHousehold(householdId) && 
        (get(/databases/$(database)/documents/household_members/$(householdId + '_' + request.auth.uid)).data.role == 'owner' ||
         get(/databases/$(database)/documents/household_members/$(householdId + '_' + request.auth.uid)).data.role == 'admin');
    }

    // --- REGRAS POR COLECÃO ---

    // 1. Catalogo Global (Read-only para logados)
    match /investmentAssets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }

    // 2. Configuracoes Especificas (ID contem o UID ou campo userId)
    match /settings/{settingId} {
      allow read, write: if isAuthenticated() && 
        (settingId == 'investment_goals_' + request.auth.uid || (resource != null && resource.data.userId == request.auth.uid));
    }

    // 2.5. Coleções relacionadas a Família / Planos
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /households/{householdId} {
      allow read: if isMemberOfHousehold(householdId);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /household_members/{memberId} {
      allow get: if isMemberOfHousehold(resource.data.householdId);
      allow list: if isAuthenticated() && isMemberOfHousehold(resource.data.householdId);
      allow create: if isAuthenticated() && (
        (request.resource.data.role == 'owner' && 
         request.resource.data.userId == request.auth.uid &&
         get(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.ownerId == request.auth.uid) ||
        (request.resource.data.userId == request.auth.uid &&
         request.resource.data.inviteToken != null &&
         get(/databases/$(database)/documents/household_invites/$(request.resource.data.inviteToken)).data.status == 'accepted' &&
         get(/databases/$(database)/documents/household_invites/$(request.resource.data.inviteToken)).data.invitedEmail == request.resource.data.email &&
         get(/databases/$(database)/documents/household_invites/$(request.resource.data.inviteToken)).data.householdId == request.resource.data.householdId)
      );
      allow update: if isAuthenticated() && (
        get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.ownerId == request.auth.uid ||
        (resource.data.userId == request.auth.uid && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.role != 'owner') || 
        (get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.ownerId == request.auth.uid && resource.data.userId != request.auth.uid)
      );
    }

    match /household_invites/{inviteId} {
      allow create: if isAuthenticated() && isHouseholdOwnerOrAdmin(request.resource.data.householdId);
      allow get: if true;
      allow list: if isAuthenticated() && (
        isMemberOfHousehold(resource.data.householdId) || 
        (resource.data.invitedEmail == request.auth.token.email)
      );
      allow update: if isAuthenticated() && (
        isHouseholdOwnerOrAdmin(resource.data.householdId) ||
        (resource.data.invitedEmail == request.auth.token.email && request.resource.data.status == 'accepted' && request.resource.data.householdId == resource.data.householdId)
      );
      allow delete: if isAuthenticated() && isHouseholdOwnerOrAdmin(resource.data.householdId);
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && isMemberOfHousehold(resource.data.householdId);
      allow write: if false;
    }

    // 3. Colecoes Multi-Tenant (Isolamento por campo userId)
    // Para read/update/delete: verifica userId no documento existente
    // Para create: verifica userId nos dados sendo criados
    match /{collectionName}/{docId} {
      allow read: if isAuthenticated() && 
        collectionName != 'users' && 
        collectionName != 'households' && 
        collectionName != 'household_members' && 
        collectionName != 'household_invites' && 
        collectionName != 'plans' && 
        collectionName != 'subscriptions' && 
        resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        collectionName != 'users' && 
        collectionName != 'households' && 
        collectionName != 'household_members' && 
        collectionName != 'household_invites' && 
        collectionName != 'plans' && 
        collectionName != 'subscriptions' && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        collectionName != 'users' && 
        collectionName != 'households' && 
        collectionName != 'household_members' && 
        collectionName != 'household_invites' && 
        collectionName != 'plans' && 
        collectionName != 'subscriptions' && 
        request.resource.data.userId == request.auth.uid;
    }

    // 4. Colecoes sem userId (owner-based)
    match /transactions/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /accounts/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /investments/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /companies/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /liabilities/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /liabilities/{liabilityId}/payments/{paymentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /budgets/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /monthly_closures/{docId} {
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /month_openings/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /investment_price_history/{docId} {
      allow read, write: if isAuthenticated() && resource.data.investmentId != null;
      allow create: if isAuthenticated();
    }

    match /categories/{docId} {
      allow read: if isAuthenticated() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.isDefault == true ||
          resource.data.isGlobal == true
        );

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.isDefault != true &&
        request.resource.data.isGlobal != true;

      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        resource.data.isDefault != true &&
        resource.data.isGlobal != true;
    }

    match /payables/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /receivables/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /cards/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    match /parcels/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || resource.data.owner == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || request.resource.data.owner == request.auth.uid);
    }

    // 5. Catalogo de Obrigacoes Fiscais (sem userId — acesso autenticado global)
    // getTaxObligations() busca todos os documentos sem filtro de userId
    match /tax_obligations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.companyId != null;
      allow update, delete: if isAuthenticated() && resource.data.companyId != null;
    }

    // 6. Sumarios Mensais (sem userId — acesso autenticado global para geracao)
    match /monthly_summaries/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // 7. Coleções B3 Investimentos (Isolamento por userId)
    match /investment_positions/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
    }

    match /investment_income/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
    }

    match /investment_imports/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
    }

    // Bloqueio padrao para seguranca
    match /{document=**} {
      allow read, write: if false;
    }
  }
}